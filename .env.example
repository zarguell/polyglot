# ─── App ───
APP_NAME=Polyglot
ENVIRONMENT=local
SECRET_KEY=change-me-to-a-long-random-string-32-chars-minimum
ENABLE_OPENAPI=true

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://polyglot:polyglot@localhost:5432/polyglot

# ─── Auth: Generic OIDC ───
# AUTH_OIDC_PROVIDER=generic
# AUTH_OIDC_CLIENT_ID=your-client-id
# AUTH_OIDC_CLIENT_SECRET=your-client-secret
# AUTH_OIDC_DISCOVERY_URL=https://your-idp.com/.well-known/openid-configuration

# ─── Auth: Microsoft Entra ID ───
# AUTH_OIDC_PROVIDER=entra
# AUTH_OIDC_CLIENT_ID=your-client-id
# AUTH_OIDC_CLIENT_SECRET=your-client-secret
# AUTH_OIDC_TENANT=your-tenant-id

# ─── Auth: Okta ───
# AUTH_OIDC_PROVIDER=okta
# AUTH_OIDC_CLIENT_ID=your-client-id
# AUTH_OIDC_CLIENT_SECRET=your-client-secret
# AUTH_OIDC_DOMAIN=your-okta-domain.okta.com

# ─── Auth: Google Workspace ───
# AUTH_OIDC_PROVIDER=google
# AUTH_OIDC_CLIENT_ID=your-client-id
# AUTH_OIDC_CLIENT_SECRET=your-client-secret

# ─── Dev ───
# AUTH_DEV_MODE=true
# INSTALLED_COMPONENTS=webhooks,smtp

# ─── Allowed hosts (comma-separated) ───
# ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# ─── CORS (comma-separated) ───
# CORS_ALLOWED_ORIGINS=http://localhost:5173
